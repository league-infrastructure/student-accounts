# DigitalOcean Droplet Configuration
# Edit these values for your project before running setup scripts.

# --- Team & Project ---
# Organization: The League
# Team: Students
# Project: App Deployment

# DigitalOcean project to assign new droplets to.
DO_PROJECT_ID="1fbf1cca-4dc5-4778-9cdd-cc35de298976"

# Authentication: scripts use the DO_LEAGUE_STUDENT_TOKEN environment variable.
# This must be a DigitalOcean Personal Access Token scoped to
# The League org → Students team. Export it in your shell profile
# (e.g. ~/.zshenv):
#
#   export DO_LEAGUE_STUDENT_TOKEN="dop_v1_..."
#
# To generate one: DigitalOcean dashboard → The League org → Students team
#   → API → Tokens → Generate New Token (read+write)

# --- Droplet Settings ---

# Droplet name prefix. The number is passed as an argument to create-droplet.sh.
# e.g. ./digital-ocean/create-droplet.sh 3 → creates "docker3"
DROPLET_NAME_PREFIX="docker"

# Region (sfo3 = San Francisco 3 — same as existing infrastructure)
DO_REGION="sfo3"

# Size slug (s-2vcpu-4gb is a good starting point for student projects)
# See: doctl compute size list
DO_SIZE="s-2vcpu-4gb"

# Base image (DigitalOcean marketplace Docker image)
DO_IMAGE="docker-20-04"

# SSH key fingerprints or IDs to add to the droplet (comma-separated)
# List keys: doctl compute ssh-key list --access-token "$DO_LEAGUE_STUDENT_TOKEN"
# 54831799 = deploy-key (shared project key, private key in digital-ocean/deploy-key)
# 54828860 = ESB@Bardsey, 54828829 = ESB@Gala (admin keys)
DO_SSH_KEYS="54831799,54828860,54828829"

# Tags applied to the droplet
DO_TAGS="student-project"

# --- Domain Settings ---

# The domain name that will point to this droplet.
# DNS is managed externally; this is used for Caddy configuration.
APP_DOMAIN="myapp.example.com"

# --- DNS (Route 53) ---
# Wildcard pattern: *.appsN.jointheleague.org → droplet IP
# The hosted zone ID for jointheleague.org in AWS Route 53.
# Find it: AWS Console → Route 53 → Hosted zones, or in CloudShell:
#   aws route53 list-hosted-zones-by-name --dns-name jointheleague.org --query 'HostedZones[0].Id' --output text
R53_HOSTED_ZONE_ID="Z077369429J1J539AIKIL"
R53_DOMAIN_BASE="jointheleague.org"

# --- Caddy Settings ---
# Caddy runs via caddy-docker-proxy (see caddy-compose.yml).
# It reads Docker labels from containers on the "caddy" network.

# Email for ACME / Let's Encrypt certificate registration
CADDY_ACME_EMAIL="it@jointheleague.org"
