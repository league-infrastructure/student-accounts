SESSION_SECRET=generate-a-strong-secret-for-production
ADMIN_PASSWORD=generate-a-strong-password-for-production

# --- Google OAuth 2.0 (passport-google-oauth20) ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://student-accounts.jointheleague.org/api/auth/google/callback

# --- GitHub OAuth 2.0 (passport-github2) ---
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://student-accounts.jointheleague.org/api/auth/github/callback

# --- Google Admin Directory API (OU detection for @jointheleague.org accounts) ---
# Required in production. Missing credentials cause @jointheleague.org sign-ins to
# be rejected with a 403 (fail-secure per RD-001).
#
# Option 1 (preferred for local dev): credentials file path.
# GOOGLE_CRED_FILE is the single canonical name. Bare filename resolves
# against config/files/; paths with slashes are used as-is.
GOOGLE_CRED_FILE=
#
# Option 2 (preferred for Docker Swarm): full service account key JSON as a single-line string.
# When the JSON key is mounted as a Docker secret and parsed inline, use this var.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_ADMIN_DELEGATED_USER_EMAIL=admin@jointheleague.org
# GOOGLE_STAFF_OU_PATH: the OU prefix that identifies staff accounts.
# @jointheleague.org accounts with an orgUnitPath starting with this value get role=staff.
# Default: /League Staff  (set explicitly to override)
GOOGLE_STAFF_OU_PATH=/League Staff

# --- Google Workspace Write Operations (Sprint 004) ---
# Required for any write operations (createUser, createOU, suspendUser, deleteUser).
# These env vars are NOT needed for read-only operations (getUserOU at sign-in).
#
# GOOGLE_STUDENT_OU_ROOT: root OU path for all student cohort OUs.
#   The OU must exist in Google Workspace before any createOU call succeeds.
#   Default: /Students  (set explicitly to override)
GOOGLE_STUDENT_OU_ROOT=/Students
#
# GOOGLE_STUDENT_DOMAIN: the domain for student Workspace accounts.
#   createUser validates primaryEmail is on this domain (guard in T002).
#   Default: students.jointheleague.org  (set explicitly to override)
GOOGLE_STUDENT_DOMAIN=students.jointheleague.org
#
# GOOGLE_WORKSPACE_WRITE_ENABLED: set to exactly "1" to allow write calls.
#   When absent or any other value, write methods throw WorkspaceWriteDisabledError.
#   Required in production for provisioning to function.
GOOGLE_WORKSPACE_WRITE_ENABLED=1

# --- Admin Role Assignment (Sprint 004) ---
# ADMIN_EMAILS: comma-separated list of @jointheleague.org email addresses
#   that receive role=admin at sign-in.
ADMIN_EMAILS=admin@jointheleague.org

# --- Pike 13 API ---
PIKE13_CLIENT_ID=your-pike13-client-id
PIKE13_CLIENT_SECRET=your-pike13-client-secret
PIKE13_ACCESS_TOKEN=your-pike13-access-token

# --- GitHub API ---
GITHUB_TOKEN=your-github-token

# --- MCP Server ---
MCP_DEFAULT_TOKEN=generate-a-strong-token-for-production

# --- AI Services ---
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Claude Team API (Sprint 005) ---
# Credentials for managing Claude Team seats (invite, remove members).
# OQ-002: env var names may need revision once the real Claude Team API docs are consulted.
#
# CLAUDE_TEAM_API_KEY: API key for the Claude Team management API.
CLAUDE_TEAM_API_KEY=your-claude-team-api-key
#
# CLAUDE_TEAM_PRODUCT_ID: The Claude Team organization/product identifier.
CLAUDE_TEAM_PRODUCT_ID=your-claude-team-product-id
#
# CLAUDE_TEAM_WRITE_ENABLED: set to exactly "1" to allow mutating calls
#   (inviteMember, removeMember). Required in production for seat provisioning.
CLAUDE_TEAM_WRITE_ENABLED=1
