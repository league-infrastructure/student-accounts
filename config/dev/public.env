DEPLOYMENT=dev
DATABASE_URL=file:../data/dev.db
APP_DOMAIN=localhost
APP_NAME="League Web App"
APP_SLUG=join-the-web-app

# OAuth callback URLs (non-secret, environment-specific)
GITHUB_CALLBACK_URL=http://localhost:5173/api/auth/github/callback
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
PIKE13_CALLBACK_URL=http://localhost:5173/api/auth/pike13/callback
PIKE13_API_BASE=https://jtl.pike13.com/api/v2/desk

# DigitalOcean Spaces endpoint and bucket (not secret)
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_BUCKET=league-student-storage
DO_SPACES_REGION=sfo3

ADMIN_EMAILS=eric.busboom@jointheleague.org              # your staff email so you get role=admin
GOOGLE_CRED_FILE=config/files/gapps-integrations-fc9a96a0f34a.json
GOOGLE_WORKSPACE_WRITE_ENABLED=1                 # opt-in to live writes
GOOGLE_STUDENT_DOMAIN=students.jointheleague.org
GOOGLE_STUDENT_OU_ROOT=/Students                 # or whatever the actual path is
GOOGLE_ADMIN_DELEGATED_USER_EMAIL=provisionbot@jointheleague.org
GOOGLE_STAFF_OU_PATH=/Staff              # or your actual staff OU
