SESSION_SECRET=dev-session-secret-change-me
ADMIN_PASSWORD=change-me

# --- Google OAuth 2.0 (passport-google-oauth20) ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# --- GitHub OAuth 2.0 (passport-github2) ---
# Create at: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_CALLBACK_URL=http://localhost:5173/api/auth/github/callback

# --- Google Admin Directory API (OU detection for @jointheleague.org accounts) ---
# Requires a service account with domain-wide delegation and Admin SDK read access.
# GOOGLE_SERVICE_ACCOUNT_JSON: full service account key JSON as a single-line string.
# Missing credentials cause @jointheleague.org sign-ins to be rejected (fail-secure RD-001).
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_ADMIN_DELEGATED_USER_EMAIL=admin@jointheleague.org
# GOOGLE_STAFF_OU_PATH: the OU prefix that identifies staff accounts (e.g. /League Staff).
# @jointheleague.org accounts with an orgUnitPath starting with this value get role=staff.
GOOGLE_STAFF_OU_PATH=/League Staff

# --- Legacy OAuth vars (kept for template compatibility — superseded above) ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Pike 13 API ---
PIKE13_CLIENT_ID=your-pike13-client-id
PIKE13_CLIENT_SECRET=your-pike13-client-secret
PIKE13_ACCESS_TOKEN=your-pike13-access-token

# --- GitHub API ---
GITHUB_TOKEN=your-github-token

# --- MCP Server ---
MCP_DEFAULT_TOKEN=dev-mcp-token-change-me

# --- AI Services ---
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
