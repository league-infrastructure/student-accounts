SESSION_SECRET=dev-session-secret-change-me
ADMIN_PASSWORD=change-me

# --- Google OAuth 2.0 (passport-google-oauth20) ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback

# --- GitHub OAuth 2.0 (passport-github2) ---
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:5173/api/auth/github/callback

# --- Google Admin Directory API (OU detection for @jointheleague.org accounts) ---
# Requires a service account with domain-wide delegation and Admin SDK read access.
# Missing credentials cause @jointheleague.org sign-ins to be rejected (fail-secure RD-001).
#
# Option 1 (preferred for local dev): credentials file path. Two env var names
# are accepted — GOOGLE_CREDENTIALS_FILE wins when both are set; the legacy name
# GOOGLE_SERVICE_ACCOUNT_FILE is also accepted as a fallback. The value is either:
#   - a bare filename (e.g. gapps-integrations-fc9a96a0f34a.json) — resolved
#     against config/files/ relative to the project root, or
#   - a path with slashes (e.g. ./config/files/foo.json or /abs/path/foo.json).
# The file path is not a secret; the file contents are. Place it in config/files/
# (gitignored). Do not commit it.
GOOGLE_CREDENTIALS_FILE=
# GOOGLE_SERVICE_ACCOUNT_FILE=  # legacy alias — use GOOGLE_CREDENTIALS_FILE instead
#
# Option 2 (preferred for Docker Swarm): full service account key JSON as a single-line string.
# Used when the file is mounted as a Docker secret and a file path is not practical.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_ADMIN_DELEGATED_USER_EMAIL=admin@jointheleague.org
# GOOGLE_STAFF_OU_PATH: the OU prefix that identifies staff accounts.
# @jointheleague.org accounts with an orgUnitPath starting with this value get role=staff.
# Default: /League Staff  (set explicitly to override)
# GOOGLE_STAFF_OU_PATH=/League Staff

# --- Google Workspace Write Operations (Sprint 004) ---
# Required for any write operations (createUser, createOU, suspendUser, deleteUser).
# These env vars are NOT needed for read-only operations (getUserOU at sign-in).
#
# GOOGLE_STUDENT_OU_ROOT: root OU path for all student cohort OUs.
#   All createOU calls create child OUs under this path.
#   Default: /Students  (set explicitly to override)
# GOOGLE_STUDENT_OU_ROOT=/Students
#
# GOOGLE_STUDENT_DOMAIN: the domain for student Workspace accounts.
#   createUser validates primaryEmail is on this domain (guard in T002).
#   Default: students.jointheleague.org  (set explicitly to override)
# GOOGLE_STUDENT_DOMAIN=students.jointheleague.org
#
# GOOGLE_WORKSPACE_WRITE_ENABLED: set to exactly "1" to allow write calls.
#   When absent or any other value, write methods throw WorkspaceWriteDisabledError.
#   Development environments should leave this unset.
# GOOGLE_WORKSPACE_WRITE_ENABLED=1

# --- Admin Role Assignment (Sprint 004) ---
# ADMIN_EMAILS: comma-separated list of @jointheleague.org email addresses
#   that receive role=admin at sign-in. Staff OU membership is still required
#   for role=staff; ADMIN_EMAILS is an additional elevation for admin users.
# ADMIN_EMAILS=admin@jointheleague.org,another-admin@jointheleague.org

# --- Pike 13 API ---
PIKE13_CLIENT_ID=your-pike13-client-id
PIKE13_CLIENT_SECRET=your-pike13-client-secret
PIKE13_ACCESS_TOKEN=your-pike13-access-token
#
# --- Pike13 API client (Sprint 006) ---
# PIKE13_API_URL: Base URL for the Pike13 REST API.
#   Set this for subdomain-specific businesses (e.g. https://BUSINESS.pike13.com/api/v2/desk).
#   Default: https://pike13.com/api/v2/desk  (set explicitly to override)
# PIKE13_API_URL=https://pike13.com/api/v2/desk
#
# PIKE13_API_BASE is accepted as a legacy alias for PIKE13_API_URL.
# PIKE13_API_BASE is lower priority — PIKE13_API_URL wins when both are set.
# PIKE13_API_BASE=
#
# PIKE13_WRITE_ENABLED: set to exactly "1" to allow write calls (updateCustomField).
#   When absent or any other value, write methods throw Pike13WriteDisabledError.
#   Leave unset in development.
# PIKE13_WRITE_ENABLED=1
#
# PIKE13_CUSTOM_FIELD_EMAIL_ID: Pike13 custom field ID for the League Email field.
#   Used by the write-back service (UC-020). Obtain from the Pike13 admin panel.
PIKE13_CUSTOM_FIELD_EMAIL_ID=
#
# PIKE13_CUSTOM_FIELD_GITHUB_ID: Pike13 custom field ID for the GitHub Username field.
#   Used by the write-back service (UC-020). Obtain from the Pike13 admin panel.
PIKE13_CUSTOM_FIELD_GITHUB_ID=

# --- GitHub API ---
GITHUB_TOKEN=your-github-token

# --- MCP Server ---
MCP_DEFAULT_TOKEN=dev-mcp-token-change-me

# --- AI Services ---
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# --- Claude Team API (Sprint 005) ---
# Credentials for managing Claude Team seats (invite, remove members).
# OQ-002: env var names may need revision once the real Claude Team API docs are consulted.
#
# CLAUDE_TEAM_API_KEY: API key for the Claude Team management API.
CLAUDE_TEAM_API_KEY=your-claude-team-api-key
#
# CLAUDE_TEAM_PRODUCT_ID: The Claude Team organization/product identifier.
CLAUDE_TEAM_PRODUCT_ID=your-claude-team-product-id
#
# CLAUDE_TEAM_WRITE_ENABLED: set to exactly "1" to allow mutating calls
#   (inviteMember, removeMember). When absent or any other value, write methods
#   throw ClaudeTeamWriteDisabledError. Leave unset in development.
# CLAUDE_TEAM_WRITE_ENABLED=1
