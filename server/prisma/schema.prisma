// Dual-adapter strategy: the adapter is selected at runtime in
// server/src/services/prisma.ts based on DATABASE_URL:
//   "file:" prefix → @prisma/adapter-better-sqlite3 (dev / integration tests)
//   anything else  → @prisma/adapter-pg (production PostgreSQL)
//
// NOTE: Prisma 7 enforces strict adapter/provider compatibility.
// @prisma/adapter-better-sqlite3 declares provider="sqlite", so the datasource
// must also say "sqlite" for dev/test to work. For production migrations against
// Postgres, prisma.config.ts supplies the postgresql:// URL and uses the pg
// adapter at runtime.
//
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Infrastructure models (unchanged from template)
// ---------------------------------------------------------------------------

// Runtime configuration store for admin-managed credentials.
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ScheduledJob {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  frequency String    // 'daily', 'weekly', 'hourly'
  enabled   Boolean   @default(true)
  lastRun   DateTime?
  nextRun   DateTime?
  lastError String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Express session store (PrismaSessionStore).
model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}

// ---------------------------------------------------------------------------
// Domain enums
// ---------------------------------------------------------------------------

enum UserRole {
  student
  staff
  admin
}

enum CreatedVia {
  social_login
  pike13_sync
  admin_created
}

enum ExternalAccountType {
  workspace
  claude
  pike13
}

enum ExternalAccountStatus {
  pending
  active
  suspended
  removed
}

// ---------------------------------------------------------------------------
// Domain models
// ---------------------------------------------------------------------------

model Cohort {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  google_ou_path String?
  created_at     DateTime @default(now())

  users          User[]
}

model User {
  id            Int        @id @default(autoincrement())
  display_name  String
  primary_email String     @unique
  role          UserRole   @default(student)
  created_via   CreatedVia
  cohort_id     Int?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  cohort            Cohort?           @relation(fields: [cohort_id], references: [id], onDelete: SetNull)
  logins            Login[]
  external_accounts ExternalAccount[]

  @@index([role])
  @@index([cohort_id])
}

model Login {
  id               Int      @id @default(autoincrement())
  user_id          Int
  provider         String   // 'google' | 'github'
  provider_user_id String
  provider_email   String?
  created_at       DateTime @default(now())

  user             User     @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@unique([provider, provider_user_id])
  @@index([user_id])
}

// Note: A partial unique index on (user_id, type) WHERE status IN ('pending','active')
// is added as raw SQL in the migration file because Prisma's DSL does not support
// partial indexes. The @@index directives below cover plain (non-partial) indexes only.
model ExternalAccount {
  id                Int                   @id @default(autoincrement())
  user_id           Int
  type              ExternalAccountType
  external_id       String?
  status            ExternalAccountStatus @default(pending)
  created_at        DateTime              @default(now())
  status_changed_at DateTime?

  user              User                  @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([type, status])
}
