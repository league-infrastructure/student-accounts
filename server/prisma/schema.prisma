// Dual-adapter strategy: the adapter is selected at runtime in
// server/src/services/prisma.ts based on DATABASE_URL:
//   "file:" prefix → @prisma/adapter-better-sqlite3 (dev / integration tests)
//   anything else  → @prisma/adapter-pg (production PostgreSQL)
//
// NOTE: Prisma 7 enforces strict adapter/provider compatibility.
// @prisma/adapter-better-sqlite3 declares provider="sqlite", so the datasource
// must also say "sqlite" for dev/test to work. For production migrations against
// Postgres, prisma.config.ts supplies the postgresql:// URL and uses the pg
// adapter at runtime.
//
// TODO(T004): When the full domain schema is applied against a fresh Postgres
// database in CI, verify that the migration SQL generated here (for SQLite)
// is equivalent to what Prisma would generate for Postgres. The schema itself
// uses no Postgres-only DDL in this sprint, so compatibility is expected.
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Infrastructure models (unchanged from template)
// ---------------------------------------------------------------------------

// Runtime configuration store for admin-managed credentials.
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ScheduledJob {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  frequency String    // 'daily', 'weekly', 'hourly'
  enabled   Boolean   @default(true)
  lastRun   DateTime?
  nextRun   DateTime?
  lastError String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Express session store (PrismaSessionStore).
model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}

// ---------------------------------------------------------------------------
// Domain enums
// ---------------------------------------------------------------------------

enum UserRole {
  student
  staff
  admin
}

enum CreatedVia {
  social_login
  pike13_sync
  admin_created
}

// ---------------------------------------------------------------------------
// Domain models
// ---------------------------------------------------------------------------

model Cohort {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  google_ou_path String?
  created_at     DateTime @default(now())

  users          User[]
}

model User {
  id            Int        @id @default(autoincrement())
  display_name  String
  primary_email String     @unique
  role          UserRole   @default(student)
  created_via   CreatedVia
  cohort_id     Int?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  cohort        Cohort?    @relation(fields: [cohort_id], references: [id], onDelete: SetNull)

  @@index([role])
  @@index([cohort_id])
}
