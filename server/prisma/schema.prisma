// Dual-adapter strategy: the adapter is selected at runtime in
// server/src/services/prisma.ts based on DATABASE_URL:
//   "file:" prefix → @prisma/adapter-better-sqlite3 (dev / integration tests)
//   anything else  → @prisma/adapter-pg (production PostgreSQL)
//
// NOTE: Prisma 7 enforces strict adapter/provider compatibility.
// @prisma/adapter-better-sqlite3 declares provider="sqlite", so the datasource
// must also say "sqlite" for dev/test to work. For production migrations against
// Postgres, prisma.config.ts supplies the postgresql:// URL and uses the pg
// adapter at runtime.
//
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Infrastructure models (unchanged from template)
// ---------------------------------------------------------------------------

// Runtime configuration store for admin-managed credentials.
model Config {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ScheduledJob {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  frequency String    // 'daily', 'weekly', 'hourly'
  enabled   Boolean   @default(true)
  lastRun   DateTime?
  nextRun   DateTime?
  lastError String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Express session store (PrismaSessionStore).
model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}

// ---------------------------------------------------------------------------
// Domain enums
// ---------------------------------------------------------------------------

enum UserRole {
  student
  staff
  admin
}

enum CreatedVia {
  social_login
  pike13_sync
  admin_created
  workspace_sync
  passphrase_signup
}

enum ExternalAccountType {
  workspace
  claude
  pike13
}

enum ExternalAccountStatus {
  pending
  active
  suspended
  removed
}

enum ProvisioningType {
  workspace
  claude
  llm_proxy
}

enum ProvisioningStatus {
  pending
  approved
  rejected
  rejected_permanent
}

enum UserApprovalStatus {
  approved
  pending
  rejected
  rejected_permanent
}

enum MergeStatus {
  pending
  approved
  rejected
  deferred
}

// ---------------------------------------------------------------------------
// Domain models
// ---------------------------------------------------------------------------

model Cohort {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  google_ou_path String?
  created_at     DateTime @default(now())

  signup_passphrase                 String?
  signup_passphrase_grant_llm_proxy Boolean   @default(false)
  signup_passphrase_expires_at      DateTime?
  signup_passphrase_created_at      DateTime?
  signup_passphrase_created_by      Int?

  users          User[]
}

model User {
  id            Int        @id @default(autoincrement())
  display_name  String
  primary_email String     @unique
  role          UserRole   @default(student)
  created_via   CreatedVia
  cohort_id     Int?
  is_active     Boolean    @default(true)
  approval_status UserApprovalStatus @default(approved)
  onboarding_completed Boolean  @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  username       String?  @unique
  password_hash  String?

  cohort            Cohort?           @relation(fields: [cohort_id], references: [id], onDelete: SetNull)
  logins            Login[]
  external_accounts ExternalAccount[]
  groups            UserGroup[]

  audit_events_as_actor  AuditEvent[]          @relation("AuditActor")
  audit_events_as_target AuditEvent[]          @relation("AuditTarget")
  provisioning_requests  ProvisioningRequest[] @relation("RequesterUser")
  provisioning_decisions ProvisioningRequest[] @relation("DeciderUser")
  merge_suggestions_a    MergeSuggestion[]     @relation("MergeUserA")
  merge_suggestions_b    MergeSuggestion[]     @relation("MergeUserB")
  merge_decisions        MergeSuggestion[]     @relation("MergeDecider")
  llm_proxy_tokens          LlmProxyToken[]
  llm_proxy_tokens_granted  LlmProxyToken[]     @relation("LlmProxyGranter")
  oauth_clients_created       OAuthClient[]            @relation("OAuthClientCreator")
  oauth_access_tokens         OAuthAccessToken[]       @relation("OAuthTokenUser")
  oauth_authorization_codes   OAuthAuthorizationCode[]
  oauth_refresh_tokens        OAuthRefreshToken[]
  oauth_consents              OAuthConsent[]

  @@index([role])
  @@index([cohort_id])
}

// ---------------------------------------------------------------------------
// Group — app-level group, independent of Google Workspace OUs (Sprint 012).
//
// Unlike Cohort (which is 1:1 with a Google OU and a required field on User),
// Group is many-to-many via UserGroup. A user can belong to any number of
// groups. Groups are the unit for bulk provisioning operations that cut
// across arbitrary sets of users.
// ---------------------------------------------------------------------------
model Group {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  signup_passphrase                 String?
  signup_passphrase_grant_llm_proxy Boolean   @default(false)
  signup_passphrase_expires_at      DateTime?
  signup_passphrase_created_at      DateTime?
  signup_passphrase_created_by      Int?

  users       UserGroup[]
}

// Many-to-many join between User and Group. Composite PK on (user_id,
// group_id) — no surrogate id is needed because callers always reference
// memberships by the pair.
model UserGroup {
  user_id    Int
  group_id   Int
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id],  references: [id], onDelete: Cascade)
  group      Group    @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@id([user_id, group_id])
  @@index([group_id])
  @@index([user_id])
}

model Login {
  id                          Int       @id @default(autoincrement())
  user_id                     Int
  provider                    String    // 'google' | 'github' | 'pike13'
  provider_user_id            String
  provider_email              String?
  provider_username           String?   // GitHub username; null for Google logins
  provider_payload            Json?
  provider_payload_updated_at DateTime?
  directory_metadata          Json?
  created_at                  DateTime  @default(now())

  user                        User         @relation(fields: [user_id], references: [id], onDelete: Restrict)
  events                      LoginEvent[]

  @@unique([provider, provider_user_id])
  @@index([user_id])
}

model LoginEvent {
  id          Int      @id @default(autoincrement())
  login_id    Int
  occurred_at DateTime @default(now())
  payload     Json
  ip          String?
  user_agent  String?

  login Login @relation(fields: [login_id], references: [id], onDelete: Cascade)

  @@index([login_id])
}

// Note: A partial unique index on (user_id, type) WHERE status IN ('pending','active')
// is added as raw SQL in the migration file because Prisma's DSL does not support
// partial indexes. The @@index directives below cover plain (non-partial) indexes only.
model ExternalAccount {
  id                    Int                   @id @default(autoincrement())
  user_id               Int
  type                  ExternalAccountType
  external_id           String?
  status                ExternalAccountStatus @default(pending)
  created_at            DateTime              @default(now())
  status_changed_at     DateTime?
  scheduled_delete_at   DateTime?

  user                  User                  @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([type, status])
}

model AuditEvent {
  id                 Int      @id @default(autoincrement())
  actor_user_id      Int?
  action             String
  target_user_id     Int?
  target_entity_type String?
  target_entity_id   String?
  details            Json?
  created_at         DateTime @default(now())

  actor              User?    @relation("AuditActor",  fields: [actor_user_id],  references: [id], onDelete: SetNull)
  target             User?    @relation("AuditTarget", fields: [target_user_id], references: [id], onDelete: SetNull)

  @@index([actor_user_id, created_at])
  @@index([target_user_id, created_at])
  @@index([action, created_at])
}

model ProvisioningRequest {
  id             Int                @id @default(autoincrement())
  user_id        Int
  requested_type ProvisioningType
  status         ProvisioningStatus @default(pending)
  decided_by     Int?
  decided_at     DateTime?
  created_at     DateTime           @default(now())

  user           User               @relation("RequesterUser", fields: [user_id],    references: [id], onDelete: Cascade)
  decider        User?              @relation("DeciderUser",   fields: [decided_by], references: [id], onDelete: SetNull)

  @@index([user_id, status])
  @@index([status, created_at])
}

model MergeSuggestion {
  id               Int         @id @default(autoincrement())
  user_a_id        Int
  user_b_id        Int
  haiku_confidence Float
  haiku_rationale  String?
  status           MergeStatus @default(pending)
  decided_by       Int?
  decided_at       DateTime?
  created_at       DateTime    @default(now())

  user_a           User        @relation("MergeUserA",   fields: [user_a_id],   references: [id], onDelete: Cascade)
  user_b           User        @relation("MergeUserB",   fields: [user_b_id],   references: [id], onDelete: Cascade)
  decider          User?       @relation("MergeDecider", fields: [decided_by],  references: [id], onDelete: SetNull)

  @@unique([user_a_id, user_b_id])
  @@index([status, created_at])
}

// ---------------------------------------------------------------------------
// OAuthClient — registry of third-party applications that can request OAuth
// tokens via the client-credentials grant (Sprint 018).
//
// client_id is a public identifier; client_secret is only stored as a
// SHA-256 hash (plaintext shown once at create/rotate, never persisted).
//
// SQLite limitation: Prisma's native String[] requires Postgres.
// redirect_uris and allowed_scopes are stored as Json (string arrays serialised
// to JSON). The service layer exposes them as string[].
// ---------------------------------------------------------------------------
model OAuthClient {
  id                  Int       @id @default(autoincrement())
  client_id           String    @unique
  client_secret_hash  String
  name                String
  description         String?
  // String[] stored as JSON — SQLite-compatible. Service layer reads/writes string[].
  redirect_uris       Json
  // String[] stored as JSON — SQLite-compatible. Service layer reads/writes string[].
  allowed_scopes      Json
  created_by          Int?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  disabled_at         DateTime?

  creator               User?                    @relation("OAuthClientCreator", fields: [created_by], references: [id], onDelete: SetNull)
  access_tokens         OAuthAccessToken[]
  authorization_codes   OAuthAuthorizationCode[]
  refresh_tokens        OAuthRefreshToken[]
  consents              OAuthConsent[]

  @@index([client_id])
}

// ---------------------------------------------------------------------------
// OAuthAccessToken — opaque bearer tokens minted by POST /oauth/token.
//
// token_hash is SHA-256 of the plaintext token (shown once in the response,
// never stored). Supports client-credentials (user_id = null) and, in future
// sprints, authorization-code tokens (user_id set).
//
// scopes stored as Json (string array) for SQLite compatibility (same pattern
// as OAuthClient.allowed_scopes).
// ---------------------------------------------------------------------------
model OAuthAccessToken {
  id              Int       @id @default(autoincrement())
  oauth_client_id Int
  user_id         Int?
  token_hash      String    @unique
  // String[] stored as JSON — SQLite-compatible.
  scopes          Json
  expires_at      DateTime
  revoked_at      DateTime?
  last_used_at    DateTime?
  created_at      DateTime  @default(now())

  oauth_client    OAuthClient @relation(fields: [oauth_client_id], references: [id], onDelete: Cascade)
  user            User?       @relation("OAuthTokenUser", fields: [user_id], references: [id], onDelete: SetNull)

  @@index([token_hash])
  @@index([oauth_client_id])
}

// ---------------------------------------------------------------------------
// OAuthAuthorizationCode — short-lived one-time-use code (Sprint 019).
//
// code_hash is SHA-256 of the plaintext code (shown once in the response).
// code_challenge stores the PKCE challenge (method always "S256").
// consumed_at is set atomically at exchange time — a non-null value means
// the code has already been used.
// ---------------------------------------------------------------------------
model OAuthAuthorizationCode {
  id                    Int       @id @default(autoincrement())
  code_hash             String    @unique
  oauth_client_id       Int
  user_id               Int
  redirect_uri          String
  // String[] stored as JSON — SQLite-compatible.
  scopes                Json
  code_challenge        String
  code_challenge_method String
  expires_at            DateTime
  consumed_at           DateTime?
  created_at            DateTime  @default(now())

  oauth_client          OAuthClient @relation(fields: [oauth_client_id], references: [id], onDelete: Cascade)
  user                  User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([oauth_client_id])
}

// ---------------------------------------------------------------------------
// OAuthRefreshToken — long-lived rotation chain (Sprint 019).
//
// token_hash is SHA-256 of the plaintext token (shown once in the response).
// replaced_by_id forms a linked list: when a token is rotated the old row
// gets replaced_by_id = new row's id. Reuse detection walks this chain.
// ---------------------------------------------------------------------------
model OAuthRefreshToken {
  id              Int       @id @default(autoincrement())
  token_hash      String    @unique
  oauth_client_id Int
  user_id         Int
  // String[] stored as JSON — SQLite-compatible.
  scopes          Json
  expires_at      DateTime
  revoked_at      DateTime?
  replaced_by_id  Int?
  created_at      DateTime  @default(now())
  last_used_at    DateTime?

  oauth_client    OAuthClient       @relation(fields: [oauth_client_id], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  replaced_by     OAuthRefreshToken?  @relation("RefreshChain", fields: [replaced_by_id], references: [id])
  predecessors    OAuthRefreshToken[] @relation("RefreshChain")

  @@index([oauth_client_id])
}

// ---------------------------------------------------------------------------
// OAuthConsent — record that user X granted scopes Y to client Z (Sprint 019).
//
// Unique on (user_id, oauth_client_id) — re-consent UPSERTS over the row.
// The find check uses ⊇ so the consent screen is only shown when the
// existing consent does not cover all requested scopes.
// ---------------------------------------------------------------------------
model OAuthConsent {
  id              Int      @id @default(autoincrement())
  user_id         Int
  oauth_client_id Int
  // String[] stored as JSON — SQLite-compatible.
  scopes          Json
  granted_at      DateTime @default(now())

  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  oauth_client    OAuthClient @relation(fields: [oauth_client_id], references: [id], onDelete: Cascade)

  @@unique([user_id, oauth_client_id])
}

// ---------------------------------------------------------------------------
// LlmProxyToken — per-user bearer token for the in-app LLM proxy (Sprint 013).
//
// The app hosts a small forwarder at /proxy/v1 that relays requests to the
// Anthropic Messages API on behalf of students. Each student who has been
// granted access has exactly one active (non-revoked, non-expired) token.
// Tokens are opaque random strings shown to the admin once at grant time;
// the hash (SHA-256 hex) is persisted for validation on every request.
// Quota is enforced via token_limit vs tokens_used with a hard cut-off.
// ---------------------------------------------------------------------------
model LlmProxyToken {
  id              Int       @id @default(autoincrement())
  user_id         Int
  token_hash      String    @unique
  // Plaintext is stored so the student can see it on their Account page.
  // These tokens are short-lived, quota-capped, and scoped to classroom
  // demo use — the security bar is deliberately low. Nullable for rows
  // created before the plaintext column existed.
  token_plaintext String?
  expires_at      DateTime
  token_limit     Int
  tokens_used     Int       @default(0)
  request_count   Int       @default(0)
  granted_by      Int?
  granted_at      DateTime  @default(now())
  revoked_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user    User  @relation(fields: [user_id],    references: [id], onDelete: Cascade)
  granter User? @relation("LlmProxyGranter", fields: [granted_by], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([user_id, revoked_at, expires_at])
}
